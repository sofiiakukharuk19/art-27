<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>Styled To-Do List</title>
 <link href="styles.css" rel="stylesheet"/>
</head>

<body>
<h2>To-Do List</h2>
<ul class="todo-list">
  <li>
    <input type="checkbox" id="task-1">
    <label for="task-1">Finish Homework</label>
    <ul class="sub-item">
      <li><a class="sub-item-link" href="https://google.com" target="_blank">Prepare for the Test</a></li>
    </ul>
  </li>

  <li>
    <input type="checkbox" id="task-2">
    <label for="task-2">Clean Room</label>
    <ul class="sub-item">
      <li><a class="sub-item-link" href="https://google.com" target="_blank">Laundry</a></li>
    </ul>
  </li>

  <li>
    <input type="checkbox" id="task-3">
    <label for="task-3">Buy Groceries</label>
    <ul class="sub-item">
      <li><a class="sub-item-link" href="https://google.com" target="_blank">Make a List</a></li>
    </ul>
  </li>

  <li>
    <input type="checkbox" id="task-4">
    <label for="task-4">Go to the Gym</label>
    <ul class="sub-item">
      <li><a class="sub-item-link" href="https://google.com" target="_blank">Cardio</a></li>
    </ul>
  </li>
</ul>
</body>

</html>
