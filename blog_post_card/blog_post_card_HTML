<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog Post Card</title>
     <link href="styles.css" rel="stylesheet"/>
</head>
<body>
 <div class="blog-post-card">
  <img class="post-img" src="https://cdn.freecodecamp.org/curriculum/labs/cover-photo.jpg" alt="cover photo">

  <div class="post-content">
    <h2 class="post-title">Studying</h2>
    <p class="post-excerpt">HTML and CSS</p>
    <a href="#" class="read-more">Read More</a>
  </div>
 </div>    
</body>
</html>
